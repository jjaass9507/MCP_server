# MCP Server Configuration
# Copy this file to config.toml and edit the values.
# You can also point to a custom path with: MCP_CONFIG=/path/to/config.toml
#
# Logging is configured via environment variables (not this file):
#   MCP_LOG_LEVEL   DEBUG | INFO | WARNING | ERROR   (default: INFO)
#   MCP_LOG_FILE    optional path; logs also written here in addition to stderr
#
# Configuration is validated at startup: a non-existent allowed_path or a
# database whose parent directory is missing will stop the server with an error.

[filesystem]
# Directories the server is allowed to read.
# All paths must be absolute. Sub-paths are automatically allowed.
# Empty list = all access denied.
allowed_paths = [
    "/home/user/data",
    "/tmp/workspace",
]

# Set to false for read-only mode (write_file and delete_file will be rejected).
allow_write = true

[database]
# Named aliases for SQLite, PostgreSQL or SQL Server databases.
# Tools accept db_name (the key) instead of a raw path or DSN.
# SQLite     → absolute file path
# PostgreSQL → postgresql://user:password@host:port/dbname
# SQL Server → mssql://user:password@host:port/dbname
[database.connections]
mydb      = "/home/user/data/mydb.sqlite"
analytics = "/home/user/data/analytics.sqlite"

# PostgreSQL examples:
# pgdb     = "postgresql://myuser:mypassword@localhost:5432/mydb"
# prod     = "postgresql://appuser:secret@db.internal:5432/production"

# SQL Server (MSSQL) example:
# NOTE: Use a Python DSN, NOT a JDBC URL. The JDBC form
# 'jdbc:sqlserver://db:1433;databaseName=fac_power;user=aa;password=aa;...'
# becomes:
# MSSQL    = "mssql://aa:aa@db:1433/fac_power"

[api]
# External HTTP APIs the server may call, addressed by a service name (the key).
# The model uses the service name (e.g. "weather"); the api_key never leaves
# the server. base_url is required; the auth fields are only needed if the
# API expects a key in a header.
#
# API Key / Bearer token style (Authorization: Bearer <key>):
# [api.services.weather]
# base_url    = "https://api.openweathermap.org/data/2.5"
# api_key     = "your-key-here"
# auth_header = "Authorization"   # header name the key goes into
# auth_prefix = "Bearer "         # prefix before the key
#
# X-API-Key style (X-API-Key: <key>):
# [api.services.someservice]
# base_url    = "https://api.example.com"
# api_key     = "abc123"
# auth_header = "X-API-Key"
# auth_prefix = ""
#
# Optional extra static headers per service:
# [api.services.weather.headers]
# Accept = "application/json"
#
# Public API with no key (just omit the api_key/auth_* fields):
# [api.services.httpbin]
# base_url = "https://httpbin.org"

[presentation]
# Default style applied to every presentation when not explicitly overridden.
# The agent does NOT need to specify these — they are applied automatically.
#
# Presets: corporate | modern | dark | minimal | tech | aurora | bright_sans | warm
default_preset      = "aurora"
#
# Fonts: Arial | Calibri | Noto Sans | Microsoft JhengHei | Microsoft YaHei | ...
# default_title_font  = "Microsoft JhengHei"
# default_body_font   = "Microsoft JhengHei"
#
# Show page number + section name in footer
# default_show_footer = true
